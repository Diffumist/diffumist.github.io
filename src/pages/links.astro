---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, services, projects, privateServices } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`Links | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle="Links">
    {
      socials.length > 0 && (
        <div class="flex max-sm:flex-col sm:items-center">
          <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
            {t.home.socialLinks}:
          </div>
          <Socials />
        </div>
      )
    }

    <h2 class="mt-8 mb-2 text-lg font-semibold">Public Services</h2>
    <ul class="list-disc pl-5 space-y-1">
      {services.map(({ name, url }) => (
        <li><a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-dashed underline-offset-4">{name}</a></li>
      ))}
    </ul>

    <h2 class="mt-8 mb-2 text-lg font-semibold">Side Projects</h2>
    <ul class="list-disc pl-5 space-y-1">
      {projects.map(({ name, url }) => (
        <li><a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-dashed underline-offset-4">{name}</a></li>
      ))}
    </ul>

    {
      privateServices.length > 0 && (
        <>
          <h2 class="mt-8 mb-2 text-lg font-semibold">Private Services</h2>
          <ul class="list-disc pl-5 space-y-1">
            {privateServices.map(({ name, url }) => (
              <li><a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-dashed underline-offset-4">{name}</a></li>
            ))}
          </ul>
        </>
      )
    }
  </Main>

  <Footer />
</Layout>
